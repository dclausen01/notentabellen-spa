# Konfiguration des Servers. Kopiere diese Datei nach `.env` und fülle die
# Werte aus. NIEMALS echte Zugangsdaten committen — `.env` ist in .gitignore.

# HTTP & Datenbank
# Frei wählbar. Im Dev-Modus mit getrenntem Frontend (Variante B) denselben
# Wert für den Vite-Proxy setzen: API_PORT (siehe packages/web/vite.config.ts).
PORT=4000
DB_PFAD=notentabellen.sqlite

# Session-Signatur (langer Zufallswert, z. B. `openssl rand -hex 32`)
JWT_SECRET=bitte-einen-langen-zufallswert-eintragen

# LDAP / Active Directory (direkter Bind)
LDAP_URL=ldaps://dc01.schule.local:636
LDAP_BIND_DN=CN=svc-notenverwaltung,OU=ServiceAccounts,DC=schule,DC=local
LDAP_BIND_PW=
LDAP_BASE_DN=DC=schule,DC=local
# {{username}} wird durch die Anmeldekennung ersetzt (AD: sAMAccountName)
LDAP_USER_FILTER=(sAMAccountName={{username}})
LDAP_LOGIN_ATTR=sAMAccountName
LDAP_NAME_ATTR=displayName
